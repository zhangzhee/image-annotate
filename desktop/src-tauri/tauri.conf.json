{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "图片标注",
  "version": "0.9.0",
  "identifier": "com.example.imageannotate",
  "build": {
    "frontendDist": "../../web",
    "devUrl": "http://localhost:8765",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "图片标注",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "webview2"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["SimpChinese"]
      }
    }
  }
}









